# QuantumHive Environment Configuration — EXAMPLE
# Copiar a .env y completar con valores reales
# NUNCA commitear el .env real

# ── LLM Engine ──
LLM_ENGINE=gemini
GROQ_API_KEY=tu_api_key_aqui
GEMINI_API_KEY=tu_api_key_aqui
OPENROUTER_API_KEY=tu_api_key_aqui

# ── Telegram ──
TELEGRAM_TOKEN=tu_bot_token
USER_TELEGRAM_ID=tu_telegram_id
TELEGRAM_WEBHOOK_URL=https://tu-dominio.onrender.com/webhook/telegram

# ── Cerebro ──
CEREBRO_PORT=5001

# ── Binance Testnet ──
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_SECRET=
BINANCE_TESTNET=true
BINANCE_TESTNET_BASE_URL=https://testnet.binancefuture.com

# ── OKX Demo (BTC-USDT-SWAP Perpetuo) ──
# Crear cuenta en okx.com → Demo Trading → API Keys
# x-simulated-trading: 1 = modo demo
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_FLAG=1
OKX_BASE_URL=https://www.okx.com
OKX_INSTRUMENT=BTC-USDT-SWAP
