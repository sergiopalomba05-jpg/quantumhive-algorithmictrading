  "animationStates": {
    "IDLE": {
      "description": "Agente en reposo, esperando tareas",
      "speed": 0,
      "behavior": "static"
    },
    "WORKING": {
      "description": "Agente trabajando en su escritorio/estación",
      "speed": 1,
      "behavior": "stationary_animation"
    },
    "ALERT": {
      "description": "Movimiento rápido a zona de compliance",
      "speed": 3,
      "behavior": "emergency_movement",
      "trigger": "COMPLIANCE_ALARM"
    },
    "MEETING": {
      "description": "Agrupación de agentes para colaboración",
      "speed": 0.5,
      "behavior": "group_gathering"
    }
  },
  "eventTriggers": {
    "COMPLIANCE_ALARM": {
      "severity": "CRITICAL",
      "description": "Drawdown del 80% en challenge/live",
      "affectedDivision": "D1",
      "action": "ALERT",
      "notification": "push"
    },
    "D2B_TRIGGER": {
      "severity": "HIGH",
      "description": "Regla D2B activada - Drawdown to Breakeven",
      "affectedDivision": "D1",
      "action": "WORKING",
      "notification": "push"
    },
    "SPLIT_PAYMENT": {
      "severity": "INFO",
      "description": "Split 40/40/20 ejecutado",
      "affectedDivision": "D2",
      "action": "MEETING",
      "notification": "log"
    },
    "BACKTEST_COMPLETE": {
      "severity": "INFO",
      "description": "Backtesting MT5 completado",
      "affectedDivision": "D12",
      "action": "WORKING",
      "notification": "log"
    }
  }
}
